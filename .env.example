# Root .env for the orchestrator's own infrastructure — the HTTP bridge that
# serves the phone, and the supervisor that watches it.
#
# Copy this file to ".env" and fill in MCP_BRIDGE_TOKEN. Everything else has a
# working default; the entries below document what each one changes.
#
# This is NOT where the search API keys go. research-mcp loads its own
# research-mcp/.env (see research-mcp/.env.example) — keys placed in this file
# never reach it.
#
# Both files are gitignored. This repo is public; keep it that way.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# The passphrase gating the OAuth approval page — the only thing between the
# public hostname and every asset behind it. The bridge refuses to start if it
# is missing or shorter than 32 characters, rather than run unprotected.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_BRIDGE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# SUPERVISOR AND ALERTS  (bridge/supervisor.mjs — reads this file directly)
# ─────────────────────────────────────────────────────────────────────────────

# Where outage alerts go when you are away from the machine. Desktop toasts and
# logs/alerts.log always happen; this is the only channel that reaches a phone.
# ntfy.sh needs no account — the topic name IS the credential, so make it
# unguessable. Anyone who guesses it can read your alerts (component names and
# failure reasons, not your data).
#   MCP_ALERT_WEBHOOK=https://ntfy.sh/some-name-nobody-would-guess
MCP_ALERT_WEBHOOK=

# ntfy (default) | slack | discord | json
MCP_ALERT_WEBHOOK_FORMAT=ntfy

# Set to 0 to silence Windows toast notifications.
MCP_ALERT_TOAST=1

# How often to repeat an alert while a component is still broken (default 30m).
# A long outage otherwise goes quiet once the restart backoff stretches out.
MCP_ALERT_REPEAT_MS=1800000

# Probe cadence, probe deadline, and how many consecutive failures before the
# supervisor kills and restarts a component. Two, not one: a single missed
# probe during a GC pause is not worth dropping live sessions over.
MCP_SUPERVISOR_INTERVAL_MS=30000
MCP_SUPERVISOR_PROBE_TIMEOUT_MS=5000
MCP_SUPERVISOR_FAILURES_BEFORE_RESTART=2

# cloudflared's metrics port, where /ready reports live connections to the
# Cloudflare edge. Must match the --metrics flag in bridge/start-all.cmd —
# change one and you must change the other, or the probe reports a permanent
# outage on a healthy tunnel.
MCP_TUNNEL_METRICS_PORT=20241

# ─────────────────────────────────────────────────────────────────────────────
# BRIDGE  (bridge/server.mjs)
# ─────────────────────────────────────────────────────────────────────────────
#
# The bridge and the supervisor load this file through the same parser
# (bridge/load-env.mjs), so a setting here means the same thing to both. That
# was not always true: start-all.cmd used to extract MCP_BRIDGE_TOKEN alone and
# start node with nothing else, so everything below was read from an
# environment that could never contain it and silently used its default —
# while the supervisor, which did read this file, acted on the value. Setting
# MCP_BRIDGE_PORT moved the probe and not the listener, which is a permanent
# false outage, with restarts, against a healthy bridge.
#
# Changing the port still means changing it in ONE more place: the tunnel's
# ingress rule in %USERPROFILE%\.cloudflared\config.yml points at
# http://localhost:8787. Change only this and the tunnel keeps dialling the old
# port — the bridge is healthy, the supervisor agrees, and the phone still gets
# nothing.

# Port the bridge listens on (127.0.0.1 only; cloudflared dials out to it).
MCP_BRIDGE_PORT=8787

# Public origin. OAuth metadata and redirect URIs must use the external URL,
# not localhost, or the connector's discovery breaks.
MCP_BRIDGE_ISSUER=https://mcp.johntapia.com

# How long an idle phone session is kept before being reaped. Claude's
# connector never closes a session explicitly — it just stops talking — so
# without this each one holds an orchestrator and its asset servers forever.
MCP_BRIDGE_SESSION_IDLE_MS=1800000

# Grace period for a session whose initialize never lands. Until then it has no
# session id, so nothing else in the process holds a reference to it.
MCP_BRIDGE_HANDSHAKE_GRACE_MS=60000

# Hard ceiling on CONCURRENT sessions; the oldest is reaped past it. The idle
# reaper above bounds sessions over time but nothing bounded them at an instant
# — the log shows three opened in 26 seconds, and each is an orchestrator that
# can warm all 22 assets at ~80MB apiece.
MCP_BRIDGE_MAX_SESSIONS=4

# ─────────────────────────────────────────────────────────────────────────────
# ADVANCED
# ─────────────────────────────────────────────────────────────────────────────

# Where `npm run backup` writes. Default "backups" is on the same drive as the
# originals — it protects against accidental deletion and corruption, not drive
# failure. Point it at a cloud-synced folder or another drive for that.
MCP_BACKUP_DIR=

# Cross-process lock timings (src/file-lock.ts). Defaults are right for normal
# use; these exist so the regression suite can drive the stale and heartbeat
# paths without waiting out a 10-second window. The orchestrator is spawned by
# Claude Desktop with no environment, so setting them here does not reach it.
# MCP_LOCK_STALE_MS=10000
# MCP_LOCK_HEARTBEAT_MS=2000
# MCP_LOCK_TIMEOUT_MS=5000
# MCP_LOCK_RETRY_MS=50
