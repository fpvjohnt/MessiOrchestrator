# research-mcp optional API keys.
# Copy this file to ".env" (in the research-mcp folder) and fill in any you have.
# All are OPTIONAL — research works keyless via DuckDuckGo + Wikipedia. Adding
# keys just improves search breadth and quality. Restart Claude Desktop after
# editing so the research server reloads.

# Brave Search — free tier at https://brave.com/search/api
BRAVE_API_KEY=

# Tavily — search API built for AI agents, free tier at https://tavily.com
TAVILY_API_KEY=

# Google Programmable Search — needs BOTH:
#   API key: https://console.cloud.google.com (enable Custom Search API)
#   Search-engine ID (cx): https://programmablesearchengine.google.com
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ---------------------------------------------------------------------------
# Structured data sources (sec_filings, kalshi_markets)
# ---------------------------------------------------------------------------
# Neither needs an API key. The one setting below is NOT a secret — it is a
# contact address the SEC REQUIRES in the User-Agent of every programmatic
# request to data.sec.gov. It is a stated condition of use, not etiquette, and
# they may block traffic without it. sec_filings works without this but warns
# in its output every time.
RESEARCH_CONTACT_EMAIL=
